# Base de datos PostgreSQL
# Cambia con tu información:
# - usuario: default "postgres"
# - password: tu contraseña
# - host: "localhost" si es local, o la URL de nube
# - puerto: 5432 por defecto
# - database: nombre de tu BD
DATABASE_URL=postgresql://postgres:password@localhost:5432/mi_api

# Clave secreta para JWT
# CAMBIAR EN PRODUCCIÓN - Usar algo fuerte y aleatorio
# Generador: https://generate-secret.vercel.app/
JWT_SECRET=tu-super-clave-secreta-cambiar-esto-en-produccion

# Puerto del servidor
PORT=3000

# Entorno: development, production, test
NODE_ENV=development
